# ZENITH_API_KEY: Required for Zenith API calls.
# Project Zenith automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the Project Zenith UI.
ZENITH_API_KEY="MY_ZENITH_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Project Zenith automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENWEATHER_API_KEY: Optional API key for OpenWeatherMap integration.
# If not specified, a free fallback weather provider (Open-Meteo) will be utilized.
OPENWEATHER_API_KEY=""
